<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VaultNote" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vault_primary</item>
        <item name="colorOnPrimary">@color/vault_on_primary</item>
        <item name="colorPrimaryContainer">@color/vault_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/vault_on_primary_container</item>
        <item name="android:colorBackground">@color/vault_background</item>
        <item name="colorOnBackground">@color/vault_on_background</item>
        <item name="colorSurface">@color/vault_surface</item>
        <item name="colorOnSurface">@color/vault_on_surface</item>
        <item name="colorSurfaceVariant">@color/vault_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/vault_on_surface_variant</item>
        <item name="colorError">@color/vault_error</item>
        <item name="colorOnError">@color/vault_on_error</item>
        <item name="colorOutline">@color/vault_outline</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="Theme.VaultNote.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/vault_splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_vaultnote_mark</item>
        <item name="postSplashScreenTheme">@style/Theme.VaultNote</item>
    </style>
</resources>
