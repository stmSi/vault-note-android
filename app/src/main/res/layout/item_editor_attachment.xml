<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/editor_attachment_card_width"
    android:layout_height="match_parent"
    android:layout_marginEnd="@dimen/space_s"
    android:clickable="true"
    android:focusable="true"
    android:minWidth="@dimen/touch_target"
    android:minHeight="@dimen/touch_target"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/vault_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/editor_attachment_thumbnail"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:padding="@dimen/space_s"
            android:scaleType="centerInside"
            android:src="@drawable/ic_document"
            app:tint="@null" />

        <TextView
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="2"
            android:paddingStart="@dimen/space_s"
            android:paddingEnd="@dimen/space_s"
            android:textAppearance="?attr/textAppearanceLabelSmall" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
